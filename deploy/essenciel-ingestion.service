[Unit]
Description=EssencIel — ingestion carburants
After=network.target

[Service]
Type=oneshot
User=<your-user>
Group=<your-user>
WorkingDirectory=/home/<your-user>/EssencIel/web
EnvironmentFile=/etc/essenciel/env
ExecStart=/home/<your-user>/EssencIel/.venv/bin/python manage.py ingest
StandardOutput=journal
StandardError=journal
